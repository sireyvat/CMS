# Copy to ".env" and fill in real values before running.

# --- Database ---
# Local Docker Compose value is set automatically in docker-compose.yml.
# For Render/other hosts, use the connection string they give you, converted to asyncpg form:
#   postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///classroom.db

# --- Telegram ---
BOT_TOKEN=123456789:8994597771:AAE1fJbce3_yeWQBnXTdwjpOy7Aud-BjN70	
TEACHER_ALERT_CHAT_ID=
# Public HTTPS URL where THIS app is reachable (Telegram requires HTTPS for Mini Apps)
WEBAPP_PUBLIC_URL=https://your-domain.example.com

# --- Teacher dashboard login ---
TEACHER_USERNAME=teacher
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
TEACHER_PASSWORD_HASH=$2b$12$0AkCy.IGsICzHKqlNw927uhUpOM1xby1zszl.gtKcEFg6ZJi7OS2G
SESSION_SECRET_KEY=please-change-this-in-production

# --- Quiz security rules ---
QUIZ_TIME_LIMIT_SECONDS=900
DAILY_QUIZ_QUESTION_COUNT=9
EXAM_QUESTION_COUNT=30
